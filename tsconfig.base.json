{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@scar/domain": ["packages/domain/src"],
      "@scar/domain/*": ["packages/domain/src/*"],
      "@scar/ui": ["packages/ui/src"],
      "@scar/ui/*": ["packages/ui/src/*"],
      "@scar/db": ["packages/db/src"],
      "@scar/db/*": ["packages/db/src/*"]
    }
  }
}
